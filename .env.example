# Database
DB_PASSWORD=your-secure-db-password
REDIS_PASSWORD=your-secure-redis-password

# Security - Generate these with: openssl rand -base64 32
JWT_SECRET=your-32-byte-jwt-secret-key-here-change-in-production
ENCRYPTION_KEY=your-32-byte-encryption-key-here-change-in-production

# Optional overrides
APP_SERVER_PORT=8080
APP_SERVER_MODE=development
APP_DATABASE_MAX_CONNS=20